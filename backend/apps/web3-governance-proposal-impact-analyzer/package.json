{
  "name": "web3-governance-proposal-impact-analyzer",
  "version": "1.0.0",
  "description": "Cross-chain Governance Proposal Impact Analyzer - AI-driven analysis of DAO governance proposals and their potential market impact",
  "private": true,
  "scripts": {
    "build": "nest build web3-governance-proposal-impact-analyzer",
    "start": "nest start web3-governance-proposal-impact-analyzer",
